{
  "name": "@mehmoodqureshi/seo-mcp",
  "version": "0.1.0",
  "description": "An SEO MCP server (stdio CLI). Free, keyless on-page & technical SEO tools — single-page and site-wide audits, robots.txt, sitemap, structured-data, broken-link and keyword checks, professional PDF reports, plus PageSpeed/Lighthouse (Google PSI or local headless Chrome) with full Core Web Vitals.",
  "author": "Mehmood Ur Rehman Qureshi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mehmoodqureshi/seo-mcp.git"
  },
  "homepage": "https://github.com/Mehmoodqureshi/seo-mcp#readme",
  "bugs": {
    "url": "https://github.com/Mehmoodqureshi/seo-mcp/issues"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "seo-mcp": "dist/src/cli.js"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "seo",
    "on-page-seo",
    "technical-seo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "start": "node dist/src/cli.js",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "pdfkit": "^0.15.2"
  },
  "optionalDependencies": {
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/pdfkit": "^0.17.6",
    "rimraf": "^5.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
